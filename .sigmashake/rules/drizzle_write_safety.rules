# drizzle_write_safety.rules
# Technology: drizzle | Capability: write

rule drizzle-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "UNSAFE_drizzle_PATTERN"
  MESSAGE "Blocked an unsafe pattern in drizzle. Use the recommended best practices for 2025/2026."
}

rule drizzle-force-updated-api {
  enabled true
  priority 80
  severity warning
  ASK write
  IF path GLOB "**/*" AND content CONTAINS "OLD_drizzle_API"
  MESSAGE "You are using an outdated API for drizzle. Please upgrade to the newer API."
}
